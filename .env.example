# Copy this file to .env and fill in. Full explanation: docs/00_prerequisites_and_setup.md

# ---- REQUIRED ----
GOOGLE_API_KEY=your-gemini-key-from-aistudio          # https://aistudio.google.com/apikey (free)
SEC_USER_AGENT=Your Name your-email@example.com       # required by SEC EDGAR for Phase 5 RAG (no signup)

# ---- Gemini model + provider config (do not change provider) ----
LLM_PROVIDER=gemini                                   # locked to gemini for this project
MODEL_NAME=gemini-2.5-flash                           # workhorse: fast + cheap, free-tier eligible
REASONING_MODEL_NAME=gemini-3.5-flash                 # planning/synthesis/judging (NOT Pro — Pro is off the free tier)
EMBEDDING_MODEL=gemini-embedding-001                  # text-embedding-004 was DEPRECATED Jan 2026 — do not use
EMBEDDING_DIM=768                                     # NEVER change after Chroma ingestion
LLM_TEMPERATURE=0

# ---- OPTIONAL (fallbacks / tracing; leave blank to skip) ----
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
LANGSMITH_API_KEY=

# ---- Local paths / logging (sensible defaults; rarely change) ----
LOG_LEVEL=INFO
CHROMA_PERSIST_DIR=.chroma
SQLITE_CHECKPOINT_PATH=.checkpoints/checkpoints.sqlite
