# Copy this file to .env and fill in. Full explanation: docs/00_prerequisites_and_setup.md
# NOTE: keep comments on their OWN lines — some .env parsers (e.g. VS Code's Jupyter
# integration) do NOT strip inline comments, which corrupts the values.

# ---- REQUIRED ----
# Get free at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-key-from-aistudio
# Required by SEC EDGAR for Phase 5 RAG (no signup — just your name + email)
SEC_USER_AGENT=Your Name your-email@example.com

# ---- Gemini model + provider config (do not change provider) ----
# Locked to gemini for this project
LLM_PROVIDER=gemini
# Workhorse: fast + cheap, free-tier eligible
MODEL_NAME=gemini-2.5-flash
# Reasoning tier for planning/synthesis/judging (NOT Pro — Pro is off the free tier)
REASONING_MODEL_NAME=gemini-3.5-flash
# Current stable embedding model (text-embedding-004 was DEPRECATED Jan 2026)
EMBEDDING_MODEL=gemini-embedding-001
# NEVER change after Chroma ingestion
EMBEDDING_DIM=768
LLM_TEMPERATURE=0

# ---- OPTIONAL (fallbacks / tracing; leave blank to skip) ----
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
LANGSMITH_API_KEY=

# ---- Local paths / logging (sensible defaults; rarely change) ----
LOG_LEVEL=INFO
CHROMA_PERSIST_DIR=.chroma
SQLITE_CHECKPOINT_PATH=.checkpoints/checkpoints.sqlite
